---
import type { Product } from '../data/products.ts';

interface Props {
  product: Product;
}

const { product } = Astro.props;

// Formateador de precios en ARS.
const formatoARS = new Intl.NumberFormat('es-AR', {
  style: 'currency',
  currency: 'ARS',
  maximumFractionDigits: 0,
});

const precioFormateado = formatoARS.format(product.price);

type EstadoStock = 'bajo' | 'agotado' | null;
const estadoStock: EstadoStock =
  product.stock === 0 ? 'agotado' : product.stock <= 3 ? 'bajo' : null;
const textoStock = estadoStock === 'agotado' ? 'Sin stock' : '¡Ultimas unidades!';
---

<article class="card">
  <div class="card-img-wrapper">
    <img src={product.image} alt={product.name} loading="lazy" width="300" height="300" />
    {estadoStock && (
      <span class={`badge badge--stock-${estadoStock} badge--sobre-imagen`}>{textoStock}</span>
    )}
  </div>
  <div class="card-body">
    <span class={`badge badge--${product.category}`}>{product.category}</span>
    <h3 class="card-title">{product.name}</h3>
    <p class="card-price">{precioFormateado}</p>
    <button type="button" class="btn-carrito">Agregar al carrito</button>
  </div>
</article>

<style>
  .card {
    background-color: var(--color-acento);
    border: var(--borde-grueso);
    box-shadow: var(--sombra-dura);
    display: flex;
    flex-direction: column;
    color: var(--color-borde);
    transition: transform 0.1s linear, box-shadow 0.1s linear;
  }

  .card:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-borde);
  }

  .card-img-wrapper {
    position: relative;
    border-bottom: var(--borde-grueso);
    background-color: var(--color-primario);
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  .card-img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 0 1rem;
  }

  .card-body {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }

  .badge {
    align-self: flex-start;
    font-family: var(--font-titulo);
    font-size: 0.55rem;
    padding: 0.35rem 0.5rem;
    border: 2px solid var(--color-borde);
    background-color: var(--color-fondo);
    color: var(--color-acento);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .badge--sobre-imagen {
    position: absolute;
    top: 0.5rem;
    left: 0.5rem;
    box-shadow: var(--sombra-dura);
    z-index: 1;
  }

  .badge--consola {
    background-color: var(--color-primario);
    color: var(--color-acento);
  }

  .badge--juego {
    background-color: var(--color-borde);
    color: var(--color-acento);
  }

  .badge--accesorio {
    background-color: var(--color-acento);
    color: var(--color-borde);
  }

  .badge--stock-bajo {
    background-color: var(--color-primario);
    color: var(--color-acento);
  }

  .badge--stock-agotado {
    background-color: var(--color-gris);
    color: var(--color-acento);
  }

  .card-title {
    font-family: var(--font-titulo);
    font-size: 0.75rem;
    color: var(--color-borde);
    line-height: 1.4;
    min-height: 2.4em;
  }

  .card-price {
    font-family: var(--font-cuerpo);
    font-size: 1.5rem;
    color: var(--color-primario);
    font-weight: 400;
    margin-top: auto;
  }

  /* Botón NES: rojo con sombra dura negra. */
  .btn-carrito {
    font-family: var(--font-titulo);
    font-size: 0.65rem;
    padding: 0.7rem 0.8rem;
    background-color: var(--color-primario);
    color: var(--color-acento);
    border: var(--borde-grueso);
    box-shadow: var(--sombra-dura);
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: transform 0.05s linear, box-shadow 0.05s linear;
  }

  .btn-carrito:hover {
    transform: translate(2px, 2px);
    box-shadow: 0 0 0 var(--color-borde);
  }

  .btn-carrito:active {
    transform: translate(4px, 4px);
    box-shadow: 0 0 0 var(--color-borde);
  }

  .btn-carrito:focus-visible {
    outline: 3px dashed var(--color-borde);
    outline-offset: 2px;
  }
</style>
